PORT=3001
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/revogue
JWT_SECRET=your-secret-key-change-in-production

# Optional: for "goes with" text embeddings (leave empty to use random fallback)
OPENAI_API_KEY=

# Payments — public URL of the React app (success/failure/return redirects)
CLIENT_APP_URL=http://localhost:5173

# eSewa ePay v2 (UAT unless ESEWA_ENV=production)
# Official Epay-v2 UAT secret (Test-credentials page) — no trailing "(". Server defaults match when unset.
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_SECRET_KEY="8gBm/:&EnhH.1/q"
# ESEWA_ENV=production

# Khalti ePayment — https://docs.khalti.com/khalti-epayment/
# Sandbox: leave empty in dev to use the public doc sample key, or set your key from https://test-admin.khalti.com/
# Production: set KHALTI_SECRET_KEY from https://admin.khalti.com/ and KHALTI_ENV=production
# (Also accepts KHALTI_LIVE_SECRET_KEY; you may paste "Key xxx" — the Key prefix is stripped.)
KHALTI_SECRET_KEY=
# KHALTI_ENV=production
